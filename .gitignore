# Python bytecode and caches
__pycache__/
*.py[cod]
*.pyc.*

# Python tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/

# Build and packaging artifacts
build/
dist/
*.egg-info/
.eggs/

# Virtual environments
.venv/
venv/
env/
ENV/

# IDE settings
.vscode/
.idea/

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Logs
*.log

# LT_scenario_gen runtime artifacts
LT_scenario_gen/error_log.txt
LT_scenario_gen/input_img/*
!LT_scenario_gen/input_img/.gitkeep
LT_scenario_gen/output_img/*
!LT_scenario_gen/output_img/.gitkeep
